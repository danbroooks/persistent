    instance PersistField Lperson where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper
            ["name", "age", "address"]
    instance PersistFieldSql Lperson where
      sqlType _ = SqlString
    instance PersistField Laddress where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper
            ["street", "city", "zip"]
    instance PersistFieldSql Laddress where
      sqlType _ = SqlString
    instance PersistField CustomPrimaryKey where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper ["anInt"]
    instance PersistFieldSql CustomPrimaryKey where
