    instance PersistField Person where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper
            ["name", "age", "foo", "address"]
    instance PersistFieldSql Person where
      sqlType _ = SqlString
    instance PersistField HasSimpleCascadeRef where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper ["person"]
    instance PersistFieldSql HasSimpleCascadeRef where
      sqlType _ = SqlString
    instance PersistField Address where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper
            ["street", "city", "zip"]
    instance PersistFieldSql Address where
      sqlType _ = SqlString
    instance PersistField NoJson where
      toPersistValue = Database.Persist.TH.entityToPersistValueHelper
      fromPersistValue
        = Database.Persist.TH.entityFromPersistValueHelper ["foo"]
    instance PersistFieldSql NoJson where
      sqlType _ = SqlString
    data Person
      = Person {personName :: !Text,
                personAge :: !(Maybe Int),
                personFoo :: !Foo,
                personAddress :: !Address}
      deriving stock (Show, Eq, Generic)
    type PersonId = Key Person
    instance PersistEntity Person where
      type PersistEntityBackend Person = SqlBackend
      data Unique Person
      newtype Key Person
        = PersonKey {unPersonKey :: (BackendKey SqlBackend)}
        deriving stock Show
        deriving stock Read
        deriving newtype Eq
        deriving newtype Ord
        deriving newtype path-pieces-0.2.1:Web.PathPieces.PathPiece
