      symbolToField = PersonName
    instance SymbolToField "age" Person (Maybe Int) where
      symbolToField = PersonAge
    instance SymbolToField "foo" Person Foo where
      symbolToField = PersonFoo
    instance SymbolToField "address" Person Address where
      symbolToField = PersonAddress
    instance SymbolToField "person" HasSimpleCascadeRef (Key Person) where
      symbolToField = HasSimpleCascadeRefPerson
    instance SymbolToField "street" Address Text where
      symbolToField = AddressStreet
    instance SymbolToField "city" Address Text where
      symbolToField = AddressCity
    instance SymbolToField "zip" Address (Maybe Int) where
      symbolToField = AddressZip
    instance SymbolToField "foo" NoJson Text where
      symbolToField = NoJsonFoo
